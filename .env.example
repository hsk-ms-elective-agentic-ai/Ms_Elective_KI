# Default: OpenAI — requires OPENAI_API_KEY (paid, no free tier)
# Get a key at https://platform.openai.com/api-keys
MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Optional: Google Gemini free tier — no credit card needed, one key covers chat + embeddings
# To switch: uncomment the two lines below and leave OPENAI_API_KEY empty
# Get a free key at https://ai.google.dev
# MODEL=gemini/gemini-3.1-flash-lite
#
# Free-tier request quotas are per model, not per key: if you hit "RESOURCE_EXHAUSTED"
# on one model, switch to another free Gemini model (e.g. gemini-2.5-flash,
# gemini-3.5-flash, gemini-3-flash-preview) to get a fresh quota, rather than waiting
# or re-requesting a key.
#
# Avoid these — confirmed broken/unavailable as of 2026-07:
# - gemini-2.0-flash / gemini-2.0-flash-lite: deprecated, no longer free
# - gemini-2.5-flash-lite: returns 404 "no longer available to new users"
# - gemini-2.5-pro: no free tier at all (paid only)

# Required for embeddings (RAG in step 5); also the chat LLM if using Gemini free tier
# Get a free key at https://ai.google.dev
GEMINI_API_KEY=

# Optional: Cohere free trial tier — no credit card needed, chat only (embeddings
# still use Gemini above; RAG in step 5 always uses the Gemini embedder).
# Trial keys are capped at 1,000 calls/month and evaluation use only.
# To switch: uncomment the two lines below and leave OPENAI_API_KEY empty
# Get a free trial key at https://dashboard.cohere.com
# MODEL=cohere/command-r-plus
# COHERE_API_KEY=

# Web search tool (step 5)
# Get a free key at https://serper.dev
SERPER_API_KEY=

# Pins the Gemini embedder's model explicitly — without this, MODEL above silently
# overrides it (litellm provider/embedder env vars collide on a shared "model" alias).
EMBEDDINGS_GOOGLE_GENERATIVE_AI_MODEL_NAME=gemini-embedding-001

CREWAI_DISABLE_TELEMETRY=true
