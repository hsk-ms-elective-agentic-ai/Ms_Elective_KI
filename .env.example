MODEL=groq/llama-3.3-70b-versatile
GROQ_API_KEY=
SERPER_API_KEY=
GEMINI_API_KEY=
# Pins the Gemini embedder's model explicitly — without this, MODEL above silently
# overrides it (litellm provider/embedder env vars collide on a shared "model" alias).
EMBEDDINGS_GOOGLE_GENERATIVE_AI_MODEL_NAME=gemini-embedding-001
CREWAI_DISABLE_TELEMETRY=true
